# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
# Channel the player hub panel gets posted to (used by: npm run post-hub)
HUB_CHANNEL_ID=

# --- Engagement + operator control ---
# Where engagement autoposts go (Term of the Day, etc.). Falls back to HUB_CHANNEL_ID.
AUTOPOST_CHANNEL_ID=
# Your Discord user id. Only this user may use the Operator Control Hub buttons.
OWNER_DISCORD_ID=
# Private/staff channel where the Operator Control Hub is posted (post-operator-hub).
STAFF_CHANNEL_ID=
# Channel OpenClaw watches. Operator "delegate" buttons post instructions here.
OPENCLAW_CHANNEL_ID=
# OpenClaw agent's Discord user id (e.g. EXE/@Techkage). Delegate messages @mention it,
# required because EXE runs with requireMention=true. Leave blank for no mention.
OPENCLAW_AGENT_ID=

NODE_ENV=development
